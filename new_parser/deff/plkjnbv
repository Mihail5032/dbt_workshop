SELECT COUNT(*) as broken_txn_count
FROM (
    SELECT retailstoreid, businessdaydate, workstationid, transactionsequencenumber
    FROM ice_baby.core_flow_ing_raw.raw_bptransaction
    WHERE transactiontypecode LIKE '10%'
      AND is_aligned_tran IS NULL
      AND businessdaydate = date '2026-04-12'
    INTERSECT
    SELECT retailstoreid, businessdaydate, workstationid, transactionsequencenumber
    FROM ice_baby.core_flow_ing_raw.raw_bptender
    WHERE transactiontypecode LIKE '10%'
      AND is_aligned_tran IS NULL
      AND businessdaydate = date '2026-04-12'
    INTERSECT
    SELECT retailstoreid, businessdaydate, workstationid, transactionsequencenumber
    FROM ice_baby.core_flow_ing_raw.raw_bpretaillineitem
    WHERE transactiontypecode LIKE '10%'
      AND is_aligned_tran IS NULL
      AND businessdaydate = date '2026-04-12'
) sub
