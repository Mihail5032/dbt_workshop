-- Транзакции, которые есть в old, но нет в new
SELECT 'missing_in_new' as status, retailstoreid, businessdaydate, workstationid, transactionsequencenumber, count(*) as cnt
FROM ice_baby.core_flow_ing_raw.raw_bptransaction
WHERE businessdaydate = date '2026-04-07'
GROUP BY retailstoreid, businessdaydate, workstationid, transactionsequencenumber
HAVING count(*) = 1

