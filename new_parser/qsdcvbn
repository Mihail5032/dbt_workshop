SELECT 
    businessdaydate,
    COUNT(*) AS duplicate_transactions
FROM (
    SELECT 
        retailstoreid, 
        businessdaydate, 
        workstationid, 
        transactionsequencenumber, 
        COUNT(*) AS qnty
    FROM ice_baby.core_flow_ing_raw.raw_bptransaction
    GROUP BY retailstoreid, businessdaydate, workstationid, transactionsequencenumber
    HAVING COUNT(*) > 1
) dupes
GROUP BY businessdaydate
ORDER BY businessdaydate
