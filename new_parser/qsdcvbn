SELECT t.retailstoreid, t.businessdaydate, t.workstationid, t.transactionsequencenumber,
       COUNT(*) as row_count,
       COUNT(is_aligned_tran) as non_null_count,
       SUM(CASE WHEN is_aligned_tran IS NULL THEN 1 ELSE 0 END) as null_count
FROM ice_baby.core_flow_ing_raw.raw_bptransaction t
WHERE t.transactiontypecode = '1014'
  AND t.is_aligned_tran IS NULL
GROUP BY 1,2,3,4
HAVING COUNT(*) > 1
LIMIT 5
