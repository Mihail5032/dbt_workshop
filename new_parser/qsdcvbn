SELECT 
    'transaction' as tbl, COUNT(*) as total, SUM(CASE WHEN is_aligned_tran IS NULL THEN 1 ELSE 0 END) as null_cnt
FROM ice_baby.core_flow_ing_raw.raw_bptransaction
WHERE retailstoreid = 'Y709' AND businessdaydate = date '2026-04-03' 
  AND workstationid = '1' AND transactionsequencenumber = '10000000003021953'
UNION ALL
