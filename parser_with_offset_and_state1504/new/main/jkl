with cte as (SELECT retailstoreid, businessdaydate, COUNT(*) AS cnt
FROM ice_baby.core_flow_ing_raw.raw_bptransaction
WHERE businessdaydate >= date '2026-04-15'
GROUP BY retailstoreid, businessdaydate, workstationid, transactionsequencenumber
HAVING COUNT(*) > 1
ORDER BY businessdaydate, retailstoreid;)

select retailstoreid, businessdaydate, sum(cnt) from cte 
group by retailstoreid, businessdaydate
