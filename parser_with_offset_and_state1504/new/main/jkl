SELECT businessdaydate,
       retailstoreid,
       workstationid,
       transactionsequencenumber,
       COUNT(*) AS cnt
FROM ice_baby.core_flow_ing_raw.raw_bptransaction
GROUP BY businessdaydate, retailstoreid, workstationid, transactionsequencenumber
HAVING COUNT(*) > 1
ORDER BY businessdaydate, retailstoreid;
