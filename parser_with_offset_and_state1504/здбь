select 
    retailstoreid,
    workstationid,
    transactionsequencenumber,
    retailsequencenumber,
    salesamount,
    normalsalesamount,
    cast(salesamount as double) - cast(normalsalesamount as double) as diff,
    retailtypecode
from ice_baby.core_flow_ing_raw.raw_bpretaillineitem
where businessdaydate = date '2026-04-09'
    and salesamount is not null
    and normalsalesamount is not null
    and salesamount <> normalsalesamount
order by diff
limit 20;
