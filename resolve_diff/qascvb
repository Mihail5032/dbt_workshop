SELECT r.retailstoreid, r.businessdaydate, r.workstationid, 
       r.transactionsequencenumber, r.retailsequencenumber,
       r.retailtypecode
FROM ice_baby.core_flow_ing.raw_bpretaillineitem r
JOIN ice_baby.core_flow_ing.raw_bplineitemextensi e
  ON r.retailstoreid = e.retailstoreid
  AND r.businessdaydate = e.businessdaydate
  AND r.workstationid = e.workstationid
  AND r.transactionsequencenumber = e.transactionsequencenumber
  AND r.retailsequencenumber = e.retailsequencenumber
WHERE e.fieldgroup = 'POS'
  AND e.fieldname = 'AUTO_MD'
  AND e.fieldvalue = 'Y'
  AND r.retailtypecode != '2043'
  AND r.businessdaydate >= date '2026-04-14'
LIMIT 20;

