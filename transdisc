1. Распределение false по типам транзакций — покажет, какие типы дают больше всего false:

SELECT transactiontypecode, is_aligned_tran, count(*) as cnt
FROM ice_baby.core_flow_ing_raw.raw_bptransaction
GROUP BY transactiontypecode, is_aligned_tran
ORDER BY transactiontypecode, is_aligned_tran

2. Примеры false для 1002/1003 — эти должны были быть скорректированы, если diff < 1.00:

SELECT t.retailstoreid, t.businessdaydate, t.workstationid, t.transactionsequencenumber,
       t.transactiontypecode,
       sum(r.salesamount) as sales_sum,
       sum(te.tenderamount) as tender_sum,
       sum(te.tenderamount) - sum(r.salesamount) as diff
FROM ice_baby.core_flow_ing_raw.raw_bptransaction t
JOIN ice_baby.core_flow_ing_raw.raw_bpretaillineitem r
  ON t.retailstoreid = r.retailstoreid
  AND t.businessdaydate = r.businessdaydate
  AND t.workstationid = r.workstationid
  AND t.transactionsequencenumber = r.transactionsequencenumber
JOIN ice_baby.core_flow_ing_raw.raw_bptender te
  ON t.retailstoreid = te.retailstoreid
  AND t.businessdaydate = te.businessdaydate
  AND t.workstationid = te.workstationid
  AND t.transactionsequencenumber = te.transactionsequencenumber
WHERE t.is_aligned_tran = 'false'
  AND t.transactiontypecode IN ('1002','1003')
GROUP BY t.retailstoreid, t.businessdaydate, t.workstationid, t.transactionsequencenumber, t.transactiontypecode
LIMIT 20

3. Размер разницы для false — покажет, сколько из них > 1.00 (не корректируются):

SELECT 
  CASE 
    WHEN abs(diff) < 1.00 THEN '< 1.00'
    WHEN abs(diff) < 10.00 THEN '1.00 - 10.00'
    WHEN abs(diff) < 100.00 THEN '10.00 - 100.00'
    ELSE '>= 100.00'
  END as diff_bucket,
  count(*) as cnt
FROM (
  SELECT t.retailstoreid, t.businessdaydate, t.workstationid, t.transactionsequencenumber,
         sum(r.salesamount) as sales_sum,
         sum(te.tenderamount) as tender_sum,
         sum(te.tenderamount) - sum(r.salesamount) as diff
  FROM ice_baby.core_flow_ing_raw.raw_bptransaction t
  JOIN ice_baby.core_flow_ing_raw.raw_bpretaillineitem r
    ON t.retailstoreid = r.retailstoreid AND t.businessdaydate = r.businessdaydate
    AND t.workstationid = r.workstationid AND t.transactionsequencenumber = r.transactionsequencenumber
  JOIN ice_baby.core_flow_ing_raw.raw_bptender te
    ON t.retailstoreid = te.retailstoreid AND t.businessdaydate = te.businessdaydate
    AND t.workstationid = te.workstationid AND t.transactionsequencenumber = te.transactionsequencenumber
  WHERE t.is_aligned_tran = 'false'
    AND t.transactiontypecode IN ('1001','1002','1003')
  GROUP BY t.retailstoreid, t.businessdaydate, t.workstationid, t.transactionsequencenumber
)
GROUP BY 1
ORDER BY 1

